From: ryzendew
Date: 2026-06-23
Subject: Fire completion callbacks immediately after enqueue operations

After each successful enqueue call, runs check_completed_callbacks() to
fire any event callbacks that are now ready, avoiding the need for a
separate polling round-trip (clFinish, clGetEventInfo, etc.).

diff -uNarp a/dlls/opencl/pe_thunks.c b/dlls/opencl/pe_thunks.c
--- a/dlls/opencl/pe_thunks.c	2026-06-23 04:59:42.599770583 -0300
+++ b/dlls/opencl/pe_thunks.c	2026-06-23 04:59:42.600782429 -0300
@@ -242,15 +242,21 @@ cl_int WINAPI clEnqueueBarrierWithWaitLi
 cl_int WINAPI clEnqueueCopyBuffer( cl_command_queue command_queue, cl_mem src_buffer, cl_mem dst_buffer, size_t src_offset, size_t dst_offset, size_t size, cl_uint num_events_in_wait_list, const cl_event* event_wait_list, cl_event* event )
 {
     struct clEnqueueCopyBuffer_params params = { command_queue, src_buffer, dst_buffer, src_offset, dst_offset, size, num_events_in_wait_list, event_wait_list, event };
+    cl_int ret;
     TRACE( "(%p, %p, %p, %Iu, %Iu, %Iu, %u, %p, %p)\n", command_queue, src_buffer, dst_buffer, src_offset, dst_offset, size, num_events_in_wait_list, event_wait_list, event );
-    return OPENCL_CALL( clEnqueueCopyBuffer, &params );
+    ret = OPENCL_CALL( clEnqueueCopyBuffer, &params );
+    check_completed_callbacks();
+    return ret;
 }
 
