-                        input_mask, e->mask);
-                return VKD3D_ERROR_NOT_IMPLEMENTED;
+                /* The input stage reads components which this stage never
+                 * writes. Real drivers tolerate this and simply read back
+                 * zero for the unwritten components; synthesize that
+                 * behaviour instead of aborting. Widen the signature mask to
+                 * cover what is read, and remember which components still
+                 * need to be zero-initialized so they can be written before
+                 * every return below. */
+                WARN("Padding signature index %u: input mask %#x reads components "
+                        "not written in output mask %#x, synthesizing zero writes.\n",
+                        i, input_mask, e->mask);
+
+                pad_mask[i] = input_mask & ~e->mask;
+                ++pad_count;
+                e->mask |= input_mask;
+                e->used_mask |= input_mask;
             }
         }
         else
@@ -4089,7 +4102,10 @@ static enum vkd3d_result vsir_program_re
 
     if (!(new_elements = vkd3d_realloc(signature->elements,
             (signature->element_count + uninit_varying_count) * sizeof(*signature->elements))))
+    {
+        vkd3d_free(pad_mask);
         return VKD3D_ERROR_OUT_OF_MEMORY;
+    }
