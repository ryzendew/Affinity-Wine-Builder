     for (i = 0; i < varying_map->varying_count; ++i)
@@ -4104,7 +4120,10 @@ static enum vkd3d_result vsir_program_re
         e = &signature->elements[signature->element_count++];
         memset(e, 0, sizeof(*e));
         if (!(e->semantic_name = vkd3d_strdup("$unused")))
+        {
+            vkd3d_free(pad_mask);
             return VKD3D_ERROR_OUT_OF_MEMORY;
+        }
         e->sysval_semantic = VKD3D_SHADER_SV_NONE;
         e->component_type = VKD3D_SHADER_COMPONENT_FLOAT;
         e->register_count = 1;
@@ -4125,7 +4144,10 @@ static enum vkd3d_result vsir_program_re
 
         loc = ins->location;
         if (!(ins = vsir_program_iterator_insert_before_and_move(&it, uninit_varying_count)))
+        {
+            vkd3d_free(pad_mask);
             return VKD3D_ERROR_OUT_OF_MEMORY;
+        }
 
         for (unsigned int j = signature->element_count - uninit_varying_count; j < signature->element_count; ++j)
         {
@@ -4140,6 +4162,50 @@ static enum vkd3d_result vsir_program_re
         }
     }
 
+    /* Write zero into the components of partially-initialized varyings
+     * (signature elements present in the output, but with a narrower write
+     * mask than what the next stage's input mask reads) before each ret, in
+     * addition to whatever the shader already writes to the rest of the
+     * register. This avoids aborting on signature mismatches that real
+     * D3D drivers tolerate. */
+    if (pad_count)
+    {
+        for (ins = vsir_program_iterator_head(&it); ins; ins = vsir_program_iterator_next(&it))
+        {
+            struct vkd3d_shader_location loc;
+            unsigned int remaining = pad_count;
+
+            if (ins->opcode != VSIR_OP_RET)
+                continue;
+
+            loc = ins->location;
+            if (!(ins = vsir_program_iterator_insert_before_and_move(&it, pad_count)))
+            {
+                vkd3d_free(pad_mask);
+                return VKD3D_ERROR_OUT_OF_MEMORY;
+            }
+
+            for (i = 0; i < orig_element_count && remaining; ++i)
+            {
+                if (!pad_mask[i])
+                    continue;
+
+                e = &signature->elements[i];
+
+                vsir_instruction_init_with_params(program, ins, &loc, VSIR_OP_MOV, 1, 1);
+                vsir_dst_operand_init_output(&ins->dst[0], VSIR_DATA_F32, e->register_index, pad_mask[i]);
+                vsir_src_operand_init(&ins->src[0], VKD3DSPR_IMMCONST, VSIR_DATA_F32, 0);
+                ins->src[0].reg.dimension = VSIR_DIMENSION_VEC4;
+                ins->src[0].swizzle = VKD3D_SHADER_NO_SWIZZLE;
+                ins = vsir_program_iterator_next(&it);
+                --remaining;
+            }
+        }
+    }
+
+    vkd3d_free(pad_mask);
+    pad_mask = NULL;
+
