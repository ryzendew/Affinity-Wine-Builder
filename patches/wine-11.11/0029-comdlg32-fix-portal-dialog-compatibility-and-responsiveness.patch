From 451239ef193cbd99270fc4ab4b7299fadd8343ad Mon Sep 17 00:00:00 2001
From: Arecsu <alejandro9r@gmail.com>
Date: Sat, 28 Mar 2026 14:13:16 -0300
Subject: [PATCH 7/7] comdlg32: fix portal dialog compatibility and
 responsiveness for Affinity

Three fixes on top of the XDG Desktop Portal patches:

- Remove FOS_DEFAULTNOMINIMODE from the unsupported options mask; this
  flag is a cosmetic hint for the native Windows dialog (compact vs full
  explorer view) and has no relevance to the portal.

- Allow IFileDialogEvents listeners with the portal. Affinity registers
  event listeners to receive OnTypeChange/OnFolderChange notifications
  which fire after the portal returns results and do not require an
  interactive Wine dialog to be present.

- Run the blocking D-Bus portal call on a separate thread and pump the
  Windows message loop on the main thread while waiting, preventing the
  calling window from appearing frozen during file picker interaction.

Co-authored-by: Alexander Wilms <f.alexander.wilms@outlook.com>
---
 dlls/comdlg32/itemdlg.c | 54 ++++++++++++++++++++++++++++++++++++-----
 1 file changed, 48 insertions(+), 6 deletions(-)

diff --git a/dlls/comdlg32/itemdlg.c b/dlls/comdlg32/itemdlg.c
index 2561d043..e6bdb116 100644
--- a/dlls/comdlg32/itemdlg.c
+++ b/dlls/comdlg32/itemdlg.c
@@ -2594,6 +2594,43 @@ static NTSTATUS call_unix_portal(enum comdlg32_unix_funcs code, void *params)
 	return WINE_UNIX_CALL(code, params);
 }
 
+struct portal_call_thread_params
+{
+    enum comdlg32_unix_funcs code;
+    void *params;
+    NTSTATUS status;
+};
+
+static DWORD WINAPI portal_call_thread(void *arg)
+{
+    struct portal_call_thread_params *p = arg;
+    p->status = WINE_UNIX_CALL(p->code, p->params);
+    return 0;
+}
+
+/* Like call_unix_portal but pumps the Windows message loop while waiting,
+ * preventing the calling window from appearing frozen during long portal calls. */
+static NTSTATUS call_unix_portal_pumping(enum comdlg32_unix_funcs code, void *params)
+{
+    struct portal_call_thread_params thread_params = { code, params, STATUS_INTERNAL_ERROR };
+    HANDLE thread;
+    MSG msg;
+
+    thread = CreateThread(NULL, 0, portal_call_thread, &thread_params, 0, NULL);
+    if (!thread) return STATUS_INTERNAL_ERROR;
+
+    while (MsgWaitForMultipleObjects(1, &thread, FALSE, INFINITE, QS_ALLINPUT) != WAIT_OBJECT_0)
+    {
+        while (PeekMessageW(&msg, NULL, 0, 0, PM_REMOVE))
+        {
+            TranslateMessage(&msg);
+            DispatchMessageW(&msg);
+        }
+    }
+    CloseHandle(thread);
+    return thread_params.status;
+}
+
 static BOOL portal_supports_itemdlg_options(FileDialogImpl *This)
 {
     DWORD unsupported_mask = FOS_ALLNONSTORAGEITEMS |
@@ -2602,7 +2639,9 @@ static BOOL portal_supports_itemdlg_options(FileDialogImpl *This)
                              FOS_HIDEMRUPLACES |
                              FOS_HIDEPINNEDPLACES |
                              FOS_DONTADDTORECENT |
-                             FOS_DEFAULTNOMINIMODE |
+                             /* FOS_DEFAULTNOMINIMODE is a cosmetic hint for the native Windows
+                              * dialog (compact vs full explorer view) and is irrelevant to the
+                              * portal — safe to ignore */
                              FOS_FORCEPREVIEWPANEON |
                              FOS_SUPPORTSTREAMABLEITEMS;
     DWORD unsupported = This->options & unsupported_mask;
@@ -2636,11 +2675,14 @@ static BOOL should_use_portal_for_itemdlg(FileDialogImpl *This)
         }
 
         /* Don't use if events listeners are registered */
+        /* Disabled: apps like Affinity register IFileDialogEvents to receive
+         * OnTypeChange/OnFolderChange notifications which fire after the portal
+         * returns results — they don't require an interactive Wine dialog.
         if (!list_empty(&This->events_clients))
         {
             TRACE("Event listeners present, not using portal\n");
             return FALSE;
-        }
+        } */
     }
 
     /* Check if Unix library is available */
@@ -2919,8 +2961,8 @@ static HRESULT try_portal_itemdlg(FileDialogImpl *This, HWND hwndOwner)
 		open_params.result_buffer[0] = 0;
 		open_params.result_buffer_len = 0;
 
-        /* Call Unix library */
-        status = call_unix_portal(unix_portal_open_file, &open_params);
+        /* Call Unix library — use pumping variant to keep message loop alive */
+        status = call_unix_portal_pumping(unix_portal_open_file, &open_params);
 
         /* Handle result */
         TRACE("portal open result: status=0x%08lx count=%u first_char=%04x grouped=%u\n",
@@ -3084,8 +3126,8 @@ static HRESULT try_portal_itemdlg(FileDialogImpl *This, HWND hwndOwner)
 		                                    (save_params.filter_count ? 1 : 0);
 		save_params.flags = 0;
 
-        /* Call Unix library */
-        status = call_unix_portal(unix_portal_save_file, &save_params);
+        /* Call Unix library — use pumping variant to keep message loop alive */
+        status = call_unix_portal_pumping(unix_portal_save_file, &save_params);
         TRACE("portal save: status=%08lx len=%u first=%04x path=%s\n",
               status, save_params.result_path_len,
               save_params.result_path[0], debugstr_w(save_params.result_path));
